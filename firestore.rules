rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidBirthday(data) {
      return data.keys().hasAll(['id', 'user', 'month', 'day']) &&
        data.id is string && data.id.size() <= 128 &&
        data.user is string && data.user.size() > 0 && data.user.size() <= 128 &&
        data.month is number && data.month >= 1 && data.month <= 12 &&
        data.day is number && data.day >= 1 && data.day <= 31 &&
        (
          !('note' in data) ||
          (data.note is string && data.note.size() <= 256)
        );
    }

    match /birthdays/{birthdayId} {
      allow read: if true;

      allow create: if isValidId(birthdayId) &&
        isValidBirthday(incoming()) &&
        incoming().keys().size() <= 5;

      allow update: if isValidBirthday(incoming()) &&
        incoming().diff(existing()).affectedKeys().hasOnly(['user', 'month', 'day', 'note']);

      allow delete: if true;
    }
  }
}
